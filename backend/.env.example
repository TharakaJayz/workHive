POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobdb
DATABASE_URL=postgresql://postgres:postgres@db:5432/jobdb
JWT_SECRET=your_jwt_secret_here
PORT=8080
# URL of your frontend (when serving from Netlify set your Netlify URL here)
FRONTEND_URL=http://localhost:3000
# Set this to the HTTPS ngrok forwarding URL when exposing local backend (e.g. https://abc123.ngrok-free.app)
# Leave empty for local-only development
NGROK_URL=
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password
