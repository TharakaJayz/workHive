# Backend runtime configuration
PORT=8080
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:3000
NGROK_URL=http://localhost:3000
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password

# PostgreSQL configuration for Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=4254
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SCHEMA=public

# Database connection string used by Prisma. Docker compose will set this automatically for the backend.
DATABASE_URL="postgresql://postgres:4254@db:5432/postgres?schema=public"
